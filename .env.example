# Optional model defaults for local runs.
# OpenAI path:
# OPENAI_API_KEY=
# AI_TEST_OFFICER_MODEL=gpt-5.4-mini
#
# OpenAI-compatible path for Volcengine Ark / Doubao:
# ARK_API_KEY=
# AI_TEST_OFFICER_MODEL=doubao-seed-2-1-turbo-260628
# AI_TEST_OFFICER_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# AI_TEST_OFFICER_OPENAI_API=chat_completions
# AI_TEST_OFFICER_DISABLE_TRACING=true
AI_TEST_OFFICER_MODEL=gpt-5.4-mini

# Internal integrations. Keep real values in local .env only.
GONGFENG_ACCESS_TOKEN=
WECOM_WEBHOOK_URL=
WECOM_WEBHOOK_KEY=

# Stable internal endpoints used by the adapter docs.
TGIT_MCP_PACKAGE=@tencent/tgit-mcp-server@latest
PLAYWRIGHT_MCP_PACKAGE=@playwright/mcp@latest
